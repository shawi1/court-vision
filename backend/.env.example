# Copy to .env and fill in
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Mock mode: if set to "1", endpoints return canned responses without API calls.
# Useful for frontend dev when keys aren't available.
COURT_VISION_MOCK=0

# CORS: comma-separated origins allowed. * for local dev only.
COURT_VISION_CORS=*
